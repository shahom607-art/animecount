generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified Boolean         @default(false)
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  sessions      Session[]
  accounts      Account[]
  watchEntries  WatchEntry[]
  favorites     Favorite[]
  recentSearches RecentSearch[]
  statistics    UserStatistics?
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PasswordReset {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Anime {
  id             String       @id @default(cuid())
  anilistId      Int?         @unique
  malId          Int?         @unique
  titleEnglish   String?
  titleJapanese  String?
  titleRomaji    String
  posterImage    String?
  bannerImage    String?
  description    String?
  genres         String[]     @default([])
  studios        String[]     @default([])
  episodes       Int          @default(12)
  duration       Int          @default(24) // in minutes
  season         String?
  year           Int?
  status         String?
  popularity     Int          @default(0)
  averageScore   Int          @default(0)
  meanScore      Int          @default(0)
  synonyms       String[]     @default([])
  trailerUrl     String?
  coverColor     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  watchEntries   WatchEntry[]
  favorites      Favorite[]
}

enum WatchStatus {
  COMPLETED
  WATCHING
  PLAN_TO_WATCH
  DROPPED
  REWATCHING
}

model WatchEntry {
  id              String      @id @default(cuid())
  userId          String
  animeId         String
  episodesWatched Int         @default(0)
  status          WatchStatus @default(WATCHING)
  rating          Float?
  notes           String?
  isPinned        Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime           Anime       @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  animeId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
}

model RecentSearch {
  id        String   @id @default(cuid())
  userId    String
  query     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStatistics {
  id                  String   @id @default(cuid())
  userId              String   @unique
  totalAnime          Int      @default(0)
  completedAnime      Int      @default(0)
  watchingAnime       Int      @default(0)
  planToWatchAnime    Int      @default(0)
  droppedAnime        Int      @default(0)
  rewatchingAnime     Int      @default(0)
  totalEpisodes       Int      @default(0)
  totalMinutes        Int      @default(0)
  averageRating       Float    @default(0)
  watchingStreak      Int      @default(0)
  lastWatchedAt       DateTime?
  favoriteGenre       String?
  favoriteStudio      String?
  mostWatchedYear     Int?
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
